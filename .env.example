# Copy to .env and fill in. .env is gitignored -- never commit real credentials.

# Data source for backtests/live: synthetic | yfinance | csv
TRADING_DATA_SOURCE=synthetic
TRADING_DATA_DIR=./data

# --- Alpaca (recommended: legal to automate; stocks + 24/7 crypto) ----------
# Paper keys work on the paper endpoint. Get them at https://alpaca.markets
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# --- Robinhood Agentic Trading (OFFICIAL MCP) -------------------------------
# Preferred: connect the MCP to Claude Code, which handles OAuth for you:
#   claude mcp add robinhood-trading --transport http https://agent.robinhood.com/mcp/trading
# For the loop-driven adapter you need an OAuth access token for the MCP:
ROBINHOOD_MCP_URL=https://agent.robinhood.com/mcp/trading
ROBINHOOD_MCP_TOKEN=

# --- Robinhood LEGACY (unofficial robin_stocks; ToS-violating -- discouraged) ---
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
ROBINHOOD_MFA_CODE=
