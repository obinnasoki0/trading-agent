# Copy to .env and fill in. .env is gitignored -- never commit real credentials.

# Data source for backtests/live: synthetic | yfinance | csv
TRADING_DATA_SOURCE=synthetic
TRADING_DATA_DIR=./data

# Robinhood (ONLY if you accept the ToS/account-lock risk -- see README).
# Automating Robinhood uses unofficial endpoints and violates its Terms of Service.
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
ROBINHOOD_MFA_CODE=
